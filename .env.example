# Copy to .env and fill values. NEVER commit .env.
# Secrets stay on this machine only.

# --- Gemini / Google AI (POC Path B) ---
# Create key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Exact API model id (not display name — no spaces)
# Free Flash-Lite class: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001

# Free-tier guardrails (~15 RPM / ~1000 RPD)
GEMINI_MAX_RPM=12
GEMINI_MAX_RPD=900
GEMINI_MAX_OUTPUT_TOKENS=512

# auto | gemini | heuristic | noop
SYNAPSE_LLM_BACKEND=auto

# --- Neo4j / Graphiti (POC) ---
# GRAPHITI_ENABLED=1
# SYNAPSE_GRAPH_BACKEND=graphiti
# GRAPHITI_MAX_PUSH_EPISODES=2
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
