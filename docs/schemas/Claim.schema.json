{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapse.local/schemas/Claim.schema.json",
  "title": "Claim",
  "description": "Query-time answer packet with citations and uncertainty.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "statement",
    "supporting_fact_ids",
    "raw_citations",
    "confidence"
  ],
  "properties": {
    "claim_id": { "type": "string", "format": "uuid" },
    "statement": { "type": "string" },
    "supporting_fact_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "raw_citations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "uncertainty_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policy_filtered": { "type": "boolean" },
    "conflict_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "route_used": { "type": ["string", "null"] },
    "idf": { "type": ["number", "null"] }
  }
}
